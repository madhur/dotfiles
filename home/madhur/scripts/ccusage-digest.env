# Claude Code usage digest config (loaded by ccusage_digest.py).
# All keys are optional; the defaults below match the committed values.

MAIL_FROM=ccusage-digest@madhur.co.in
MAIL_TO=ahuja.madhur@gmail.com

# Rolling window length, in days (today inclusive).
WINDOW_DAYS=7

# How to invoke ccusage. Default streams the latest from npm (no install needed).
# Pin or point at a global install to avoid the per-run download, e.g.:
#   CCUSAGE_CMD=ccusage
#   CCUSAGE_CMD=npx ccusage@20.0.6
CCUSAGE_CMD=npx ccusage@latest
