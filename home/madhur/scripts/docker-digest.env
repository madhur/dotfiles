# Docker daily digest config (loaded by docker_digest.py).
# All keys are optional; the defaults below match the committed values.

MAIL_FROM=docker-digest@madhur.co.in
MAIL_TO=ahuja.madhur@gmail.com

# Homelab compose root — each immediate subfolder is treated as one "stack" and
# sized with `sudo -n du`. Most data dirs are root-owned, hence sudo.
DOCKER_ROOT=/home/madhur/docker

# How many rows to show in the "top by space" tables.
TOP_N=5

# Send the mail even when nothing looks noteworthy (no stopped/unhealthy, etc.).
# The digest is informational, so default true.
SEND_WHEN_EMPTY=true
